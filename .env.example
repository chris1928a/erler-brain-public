# =============================================================
# Erler Brain — Environment Variables (example)
# Copy to .env and fill in your own values. NEVER commit .env.
# =============================================================

# --- Telegram (required) ---
# Create a bot via @BotFather on Telegram, copy the token.
TELEGRAM_BOT_TOKEN=123456:ABCdefGHIjklMNOpqrSTUvwxYZ
# Your numeric Telegram user ID. Run scripts/get_user_id.py and DM your bot once.
ALLOWED_USER_ID=123456789

# --- AI Models (required: at least one) ---
# Anthropic for high-stakes reasoning (drafts, contracts, escalations)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Google Gemini for cheap, high-volume routing & intent detection
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional: override the system prompt loaded by services/claude.py
# BRAIN_SYSTEM_PROMPT="You are my assistant. Reply in English."

# --- Google Workspace (optional, for Gmail / Drive / Calendar) ---
# OAuth credentials as a JSON string (single line). Get via Google Cloud Console.
# Required keys: refresh_token, client_id, client_secret
GOOGLE_CREDENTIALS_JSON={"refresh_token":"1//xxxx","client_id":"xxx.apps.googleusercontent.com","client_secret":"xxx"}

# --- WhatsApp via Evolution API (optional) ---
# Self-hosted Evolution API instance. https://github.com/EvolutionAPI/evolution-api
EVOLUTION_API_URL=https://your-evolution-host.com
EVOLUTION_API_KEY=your-instance-api-key
EVOLUTION_INSTANCE=your-instance-name

# --- AWS (optional, for S3-backed session storage) ---
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SESSION_BUCKET=your-bucket-name
